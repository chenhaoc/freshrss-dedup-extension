<?php
declare(strict_types=1);
/** @var TitleDedupExtension $this */

$rules = $this->currentRules();
if ($rules === []) {
    $rules = [[
        'name' => '',
        'enabled' => true,
        'source_feed_ids' => [],
        'source_feed_names' => [],
        'target_feed_ids' => [],
        'target_feed_names' => [],
        'lookback_days' => 14,
        'normalize_whitespace' => true,
        'normalize_case' => true,
        'strip_punctuation' => true,
    ]];
}

$feeds = $this->feedOptions();
$feedLabelMap = [];
foreach ($feeds as $feed) {
    $feedLabelMap[$feed['id']] = $feed['label'];
}

if (!function_exists('titleDedupNormalizeEnabled')) {
    function titleDedupNormalizeEnabled($rule): bool
    {
        if (!empty($rule['normalize_all'])) {
            return true;
        }

        return !empty($rule['normalize_whitespace'])
            || !empty($rule['normalize_case'])
            || !empty($rule['strip_punctuation']);
    }
}

if (!function_exists('titleDedupRenderFeedChip')) {
    function titleDedupRenderFeedChip($ruleIndex, $side, $inputName, $feedId, $feedLabel): string
    {
        ob_start();
        ?>
        <span class="title-dedup-feed-chip" data-feed-id="<?php echo htmlspecialchars($feedId, ENT_QUOTES, 'UTF-8'); ?>">
            <span class="title-dedup-feed-chip-label"><?php echo htmlspecialchars($feedLabel, ENT_QUOTES, 'UTF-8'); ?></span>
            <button
                type="submit"
                class="title-dedup-chip-remove"
                name="rule_action"
                value="remove_<?php echo htmlspecialchars($side . ':' . $ruleIndex . ':' . $feedId, ENT_QUOTES, 'UTF-8'); ?>"
                aria-label="移除"
            >×</button>
            <input type="hidden" name="<?php echo htmlspecialchars($inputName, ENT_QUOTES, 'UTF-8'); ?>" value="<?php echo htmlspecialchars($feedId, ENT_QUOTES, 'UTF-8'); ?>">
        </span>
        <?php
        return ob_get_clean();
    }
}

if (!function_exists('titleDedupRenderFeedPanel')) {
    function titleDedupRenderFeedPanel($ruleIndex, $side, $feeds, $feedLabelMap, $selectedIds, $title, $help): string
    {
        ob_start();
        $inputName = 'rules[' . $ruleIndex . '][' . $side . '_feed_ids][]';
        ?>
        <div class="title-dedup-feed-panel" data-feed-panel data-input-name="<?php echo htmlspecialchars($inputName, ENT_QUOTES, 'UTF-8'); ?>">
            <div class="title-dedup-feed-panel-title"><?php echo htmlspecialchars($title, ENT_QUOTES, 'UTF-8'); ?></div>
            <div class="title-dedup-feed-panel-help"><?php echo htmlspecialchars($help, ENT_QUOTES, 'UTF-8'); ?></div>
            <table class="title-dedup-panel-table" cellspacing="0" cellpadding="0" border="0">
                <tr>
                    <td class="title-dedup-panel-select">
                        <select
                            class="title-dedup-picker"
                            data-role="feed-picker"
                            name="rules[<?php echo htmlspecialchars((string)$ruleIndex, ENT_QUOTES, 'UTF-8'); ?>][<?php echo htmlspecialchars($side, ENT_QUOTES, 'UTF-8'); ?>_feed_picker]"
                        >
                            <option value="">选择订阅…</option>
                            <?php foreach ($feeds as $feed): ?>
                                <option value="<?php echo htmlspecialchars($feed['id'], ENT_QUOTES, 'UTF-8'); ?>" data-feed-label="<?php echo htmlspecialchars($feed['label'], ENT_QUOTES, 'UTF-8'); ?>">
                                    <?php echo htmlspecialchars($feed['label'], ENT_QUOTES, 'UTF-8'); ?>
                                </option>
                            <?php endforeach; ?>
                        </select>
                    </td>
                    <td class="title-dedup-panel-button">
                        <button
                            type="submit"
                            class="btn"
                            name="rule_action"
                            value="add_<?php echo htmlspecialchars($side . ':' . $ruleIndex, ENT_QUOTES, 'UTF-8'); ?>"
                        >添加</button>
                    </td>
                </tr>
            </table>
            <div class="title-dedup-feed-chips" data-role="feed-chip-list">
                <?php foreach ($selectedIds as $feedId): ?>
                    <?php if (!isset($feedLabelMap[$feedId])) { continue; } ?>
                    <?php echo titleDedupRenderFeedChip($ruleIndex, $side, $inputName, $feedId, $feedLabelMap[$feedId]); ?>
                <?php endforeach; ?>
            </div>
        </div>
        <?php
        return ob_get_clean();
    }
}

if (!function_exists('titleDedupRenderRuleCard')) {
    function titleDedupRenderRuleCard($index, $rule, $feeds, $feedLabelMap, $sourceSelectedIds, $targetSelectedIds): string
    {
        ob_start();
        $normalizeEnabled = titleDedupNormalizeEnabled($rule);
        ?>
        <section class="title-dedup-rule-card" data-title-dedup-rule>
            <hr class="title-dedup-rule-divider">
            <table class="title-dedup-head-table" cellspacing="0" cellpadding="0" border="0">
                <tr>
                    <td class="title-dedup-head-label">
                        <label for="rule_name_<?php echo htmlspecialchars((string)$index, ENT_QUOTES, 'UTF-8'); ?>">规则名</label>
                    </td>
                    <td class="title-dedup-head-input">
                        <input
                            type="text"
                            id="rule_name_<?php echo htmlspecialchars((string)$index, ENT_QUOTES, 'UTF-8'); ?>"
                            name="rules[<?php echo htmlspecialchars((string)$index, ENT_QUOTES, 'UTF-8'); ?>][name]"
                            value="<?php echo htmlspecialchars((string)($rule['name'] ?? ''), ENT_QUOTES, 'UTF-8'); ?>"
                            placeholder="例如：36Kr-AI 去重"
                        >
                    </td>
                    <td class="title-dedup-head-check">
                        <label for="rule_enabled_<?php echo htmlspecialchars((string)$index, ENT_QUOTES, 'UTF-8'); ?>">
                            <input
                                type="checkbox"
                                id="rule_enabled_<?php echo htmlspecialchars((string)$index, ENT_QUOTES, 'UTF-8'); ?>"
                                name="rules[<?php echo htmlspecialchars((string)$index, ENT_QUOTES, 'UTF-8'); ?>][enabled]"
                                value="1"
                                <?php echo !isset($rule['enabled']) || $rule['enabled'] ? 'checked' : ''; ?>
                            >
                            启用
                        </label>
                    </td>
                    <td class="title-dedup-head-button">
                        <button
                            type="submit"
                            class="btn"
                            name="rule_action"
                            value="remove_rule:<?php echo htmlspecialchars((string)$index, ENT_QUOTES, 'UTF-8'); ?>"
                        >删除规则组</button>
                    </td>
                </tr>
            </table>

            <div class="title-dedup-spacer">&nbsp;</div>
            <?php
            echo titleDedupRenderFeedPanel(
                $index,
                'source',
                $feeds,
                $feedLabelMap,
                $sourceSelectedIds,
                '参考源',
                '这些源里出现过的同标题文章，会作为去重依据'
            );
            ?>

            <div class="title-dedup-spacer">&nbsp;</div>
            <?php
            echo titleDedupRenderFeedPanel(
                $index,
                'target',
                $feeds,
                $feedLabelMap,
                $targetSelectedIds,
                '目标源',
                '命中的文章会自动已读'
            );
            ?>

            <div class="title-dedup-spacer">&nbsp;</div>
            <table class="title-dedup-meta-table" cellspacing="0" cellpadding="0" border="0">
                <tr>
                    <td class="title-dedup-meta-label">
                        <label for="rule_lookback_<?php echo htmlspecialchars((string)$index, ENT_QUOTES, 'UTF-8'); ?>">回看天数</label>
                    </td>
                    <td class="title-dedup-meta-value">
                        <input
                            type="number"
                            id="rule_lookback_<?php echo htmlspecialchars((string)$index, ENT_QUOTES, 'UTF-8'); ?>"
                            name="rules[<?php echo htmlspecialchars((string)$index, ENT_QUOTES, 'UTF-8'); ?>][lookback_days]"
                            min="1"
                            max="3650"
                            value="<?php echo htmlspecialchars((string)($rule['lookback_days'] ?? 14), ENT_QUOTES, 'UTF-8'); ?>"
                        >
                    </td>
                </tr>
            </table>

            <table class="title-dedup-meta-table title-dedup-meta-table-last" cellspacing="0" cellpadding="0" border="0">
                <tr>
                    <td class="title-dedup-meta-label">
                        <label for="rule_normalize_<?php echo htmlspecialchars((string)$index, ENT_QUOTES, 'UTF-8'); ?>">归一化</label>
                    </td>
                    <td class="title-dedup-meta-value">
                        <label for="rule_normalize_<?php echo htmlspecialchars((string)$index, ENT_QUOTES, 'UTF-8'); ?>">
                            <input
                                type="checkbox"
                                id="rule_normalize_<?php echo htmlspecialchars((string)$index, ENT_QUOTES, 'UTF-8'); ?>"
                                name="rules[<?php echo htmlspecialchars((string)$index, ENT_QUOTES, 'UTF-8'); ?>][normalize_all]"
                                value="1"
                                <?php echo $normalizeEnabled ? 'checked' : ''; ?>
                            >
                            压缩空白、忽略大小写、删除标点符号
                        </label>
                    </td>
                </tr>
            </table>
            <hr class="title-dedup-rule-divider title-dedup-rule-divider-bottom">
        </section>
        <?php
        return ob_get_clean();
    }
}
