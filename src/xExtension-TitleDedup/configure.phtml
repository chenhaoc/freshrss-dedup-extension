<?php
declare(strict_types=1);
/** @var TitleDedupExtension $this */

$rules = $this->currentRules();
if ($rules === []) {
    $rules = [[
        'name' => '',
        'enabled' => true,
        'source_feed_ids' => [],
        'source_feed_names' => [],
        'target_feed_ids' => [],
        'target_feed_names' => [],
        'lookback_days' => 14,
        'normalize_whitespace' => true,
        'normalize_case' => true,
        'strip_punctuation' => false,
    ]];
}

$feeds = $this->feedOptions();
$feedLabelMap = [];
foreach ($feeds as $feed) {
    $feedLabelMap[$feed['id']] = $feed['label'];
}

if (!function_exists('titleDedupJsAddRule')) {
    function titleDedupJsAddRule(): string
    {
        return "var root=document.getElementById('title-dedup-rules');var tpl=document.getElementById('title-dedup-rule-template');if(!root||!tpl){return false;}var idx=Date.now();var html=tpl.innerHTML.replace(/__INDEX__/g,String(idx));var wrap=document.createElement('div');wrap.innerHTML=html.trim();if(wrap.firstElementChild){root.appendChild(wrap.firstElementChild);}return false;";
    }
}

if (!function_exists('titleDedupJsRemoveRule')) {
    function titleDedupJsRemoveRule(): string
    {
        return "var c=this.closest('[data-title-dedup-rule]');if(c){c.remove();}return false;";
    }
}

if (!function_exists('titleDedupJsAddFeed')) {
    function titleDedupJsAddFeed(): string
    {
        return "var p=this.closest('[data-feed-panel]');if(!p){return false;}var s=p.querySelector('[data-role=feed-picker]');var l=p.querySelector('[data-role=feed-chip-list]');var n=p.dataset.inputName;if(!s||!l||!n){return false;}var i=s.value;if(!i){return false;}var e=Array.from(l.querySelectorAll('[data-feed-id]')).some(function(c){return c.dataset.feedId===i;});if(e){s.value='';return false;}var o=s.options[s.selectedIndex];if(!o){return false;}var chip=document.createElement('span');chip.className='title-dedup-feed-chip';chip.dataset.feedId=i;chip.innerHTML='<span class=\"title-dedup-feed-chip-label\"></span><button type=\"button\" class=\"title-dedup-chip-remove\" aria-label=\"移除\">×</button><input type=\"hidden\">';chip.querySelector('.title-dedup-feed-chip-label').textContent=o.text;chip.querySelector('input').name=n;chip.querySelector('input').value=i;l.appendChild(chip);s.value='';return false;";
    }
}

if (!function_exists('titleDedupJsRemoveFeed')) {
    function titleDedupJsRemoveFeed(): string
    {
        return "var c=this.closest('.title-dedup-feed-chip');if(c){c.remove();}return false;";
    }
}

if (!function_exists('titleDedupRenderFeedChip')) {
    function titleDedupRenderFeedChip($ruleIndex, $side, $inputName, $feedId, $feedLabel): string
    {
        ob_start();
        ?>
        <span class="title-dedup-feed-chip" data-feed-id="<?php echo htmlspecialchars($feedId, ENT_QUOTES, 'UTF-8'); ?>">
            <span class="title-dedup-feed-chip-label"><?php echo htmlspecialchars($feedLabel, ENT_QUOTES, 'UTF-8'); ?></span>
            <button
                type="submit"
                class="title-dedup-chip-remove"
                name="rule_action"
                value="remove_<?php echo htmlspecialchars($side . ':' . $ruleIndex . ':' . $feedId, ENT_QUOTES, 'UTF-8'); ?>"
                aria-label="移除"
            >×</button>
            <input type="hidden" name="<?php echo htmlspecialchars($inputName, ENT_QUOTES, 'UTF-8'); ?>" value="<?php echo htmlspecialchars($feedId, ENT_QUOTES, 'UTF-8'); ?>">
        </span>
        <?php
        return ob_get_clean();
    }
}

if (!function_exists('titleDedupRenderFeedPanel')) {
    function titleDedupRenderFeedPanel($ruleIndex, $side, $feeds, $feedLabelMap, $selectedIds, $title, $help): string
    {
        ob_start();
        $inputName = 'rules[' . $ruleIndex . '][' . $side . '_feed_ids][]';
        ?>
        <div class="title-dedup-feed-panel" data-feed-panel data-input-name="<?php echo htmlspecialchars($inputName, ENT_QUOTES, 'UTF-8'); ?>">
            <div class="title-dedup-feed-panel-head">
                <span class="title-dedup-feed-panel-title"><?php echo htmlspecialchars($title, ENT_QUOTES, 'UTF-8'); ?></span>
                <select
                    class="title-dedup-picker"
                    data-role="feed-picker"
                    name="rules[<?php echo htmlspecialchars((string)$ruleIndex, ENT_QUOTES, 'UTF-8'); ?>][<?php echo htmlspecialchars($side, ENT_QUOTES, 'UTF-8'); ?>_feed_picker]"
                >
                    <option value="">选择订阅…</option>
                    <?php foreach ($feeds as $feed): ?>
                        <option value="<?php echo htmlspecialchars($feed['id'], ENT_QUOTES, 'UTF-8'); ?>" data-feed-label="<?php echo htmlspecialchars($feed['label'], ENT_QUOTES, 'UTF-8'); ?>">
                            <?php echo htmlspecialchars($feed['label'], ENT_QUOTES, 'UTF-8'); ?>
                        </option>
                    <?php endforeach; ?>
                </select>
                <button
                    type="submit"
                    class="btn"
                    name="rule_action"
                    value="add_<?php echo htmlspecialchars($side . ':' . $ruleIndex, ENT_QUOTES, 'UTF-8'); ?>"
                >添加</button>
            </div>
            <div class="title-dedup-feed-chips" data-role="feed-chip-list">
                <?php foreach ($selectedIds as $feedId): ?>
                    <?php if (!isset($feedLabelMap[$feedId])) { continue; } ?>
                    <?php echo titleDedupRenderFeedChip($ruleIndex, $side, $inputName, $feedId, $feedLabelMap[$feedId]); ?>
                <?php endforeach; ?>
            </div>
            <div class="form-help"><?php echo htmlspecialchars($help, ENT_QUOTES, 'UTF-8'); ?></div>
        </div>
        <?php
        return ob_get_clean();
    }
}

if (!function_exists('titleDedupRenderRuleCard')) {
    function titleDedupRenderRuleCard($index, $rule, $feeds, $feedLabelMap, $sourceSelectedIds, $targetSelectedIds): string
    {
        ob_start();
        ?>
        <section class="title-dedup-rule-card" data-title-dedup-rule>
            <div class="form-group">
                <label class="group-name" for="rule_name_<?php echo htmlspecialchars((string)$index, ENT_QUOTES, 'UTF-8'); ?>">规则名</label>
                <div class="group-controls">
                    <input
                        type="text"
                        id="rule_name_<?php echo htmlspecialchars((string)$index, ENT_QUOTES, 'UTF-8'); ?>"
                        name="rules[<?php echo htmlspecialchars((string)$index, ENT_QUOTES, 'UTF-8'); ?>][name]"
                        value="<?php echo htmlspecialchars((string)($rule['name'] ?? ''), ENT_QUOTES, 'UTF-8'); ?>"
                        placeholder="例如：36Kr-AI 去重"
                    >
                </div>
            </div>

            <div class="form-group">
                <label class="group-name" for="rule_enabled_<?php echo htmlspecialchars((string)$index, ENT_QUOTES, 'UTF-8'); ?>">启用</label>
                <div class="group-controls">
                    <input
                        type="checkbox"
                        id="rule_enabled_<?php echo htmlspecialchars((string)$index, ENT_QUOTES, 'UTF-8'); ?>"
                        name="rules[<?php echo htmlspecialchars((string)$index, ENT_QUOTES, 'UTF-8'); ?>][enabled]"
                        value="1"
                        <?php echo !isset($rule['enabled']) || $rule['enabled'] ? 'checked' : ''; ?>
                    >
                </div>
            </div>

            <div class="title-dedup-feed-grid">
                <?php
                echo titleDedupRenderFeedPanel(
                    $index,
                    'source',
                    $feeds,
                    $feedLabelMap,
                    $sourceSelectedIds,
                    '参考源',
                    '这些源里出现过的同标题文章，会作为去重依据'
                );
                echo titleDedupRenderFeedPanel(
                    $index,
                    'target',
                    $feeds,
                    $feedLabelMap,
                    $targetSelectedIds,
                    '目标源',
                    '命中的文章会自动已读'
                );
                ?>
            </div>

            <div class="form-group">
                <label class="group-name" for="rule_lookback_<?php echo htmlspecialchars((string)$index, ENT_QUOTES, 'UTF-8'); ?>">回看天数</label>
                <div class="group-controls">
                    <input
                        type="number"
                        id="rule_lookback_<?php echo htmlspecialchars((string)$index, ENT_QUOTES, 'UTF-8'); ?>"
                        name="rules[<?php echo htmlspecialchars((string)$index, ENT_QUOTES, 'UTF-8'); ?>][lookback_days]"
                        min="1"
                        max="3650"
                        value="<?php echo htmlspecialchars((string)($rule['lookback_days'] ?? 14), ENT_QUOTES, 'UTF-8'); ?>"
                    >
                </div>
            </div>

            <div class="form-group">
                <label class="group-name">归一化</label>
                <div class="group-controls">
                    <label>
                        <input
                            type="checkbox"
                            name="rules[<?php echo htmlspecialchars((string)$index, ENT_QUOTES, 'UTF-8'); ?>][normalize_whitespace]"
                            value="1"
                            <?php echo !isset($rule['normalize_whitespace']) || $rule['normalize_whitespace'] ? 'checked' : ''; ?>
                        >
                        压缩空白
                    </label>
                    <label style="margin-left:12px;">
                        <input
                            type="checkbox"
                            name="rules[<?php echo htmlspecialchars((string)$index, ENT_QUOTES, 'UTF-8'); ?>][normalize_case]"
                            value="1"
                            <?php echo !isset($rule['normalize_case']) || $rule['normalize_case'] ? 'checked' : ''; ?>
                        >
                        忽略大小写
                    </label>
                    <div class="form-help">标点和符号会在比较前自动移除</div>
                </div>
            </div>

            <div class="form-group form-actions">
                <div class="group-controls">
                    <button
                        type="submit"
                        class="btn"
                        name="rule_action"
                        value="remove_rule:<?php echo htmlspecialchars((string)$index, ENT_QUOTES, 'UTF-8'); ?>"
                    >删除规则组</button>
                </div>
            </div>
        </section>
        <?php
        return ob_get_clean();
    }
}
?>
<form action="<?php echo _url('extension', 'configure', 'e', urlencode($this->getName())); ?>" method="post">
    <input type="hidden" name="_csrf" value="<?php echo FreshRSS_Auth::csrfToken(); ?>" />
    <h2>Title Dedup</h2>
    <p>直接选择现有订阅作为参考源和目标源，支持多个规则组。</p>

    <div id="title-dedup-rules">
        <?php foreach (array_values($rules) as $index => $rule): ?>
            <?php
            $sourceSelectedIds = $this->selectedFeedIds($rule, 'source');
            $targetSelectedIds = $this->selectedFeedIds($rule, 'target');
            echo titleDedupRenderRuleCard($index, $rule, $feeds, $feedLabelMap, $sourceSelectedIds, $targetSelectedIds);
            ?>
        <?php endforeach; ?>
    </div>

    <template id="title-dedup-rule-template">
        <?php
        $blankRule = [
            'name' => '',
            'enabled' => true,
            'source_feed_ids' => [],
            'source_feed_names' => [],
            'target_feed_ids' => [],
            'target_feed_names' => [],
            'lookback_days' => 14,
            'normalize_whitespace' => true,
            'normalize_case' => true,
            'strip_punctuation' => false,
        ];
        echo titleDedupRenderRuleCard('__INDEX__', $blankRule, $feeds, $feedLabelMap, [], []);
        ?>
    </template>

    <div class="form-group form-actions">
        <div class="group-controls">
            <button type="submit" class="btn" name="rule_action" value="add_rule">新增规则组</button>
            <button type="submit" class="btn btn-important">保存</button>
        </div>
    </div>
</form>

